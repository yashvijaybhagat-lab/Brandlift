# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is in .gitignore.

# ── Auth ────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # openssl rand -base64 32

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI / ML ─────────────────────────────────────────────────
GEMINI_API_KEY=                         # console.cloud.google.com
ANTHROPIC_API_KEY=                      # console.anthropic.com
REPLICATE_API_TOKEN=                    # replicate.com/account/api-tokens

# ── Storage ─────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=                  # vercel.com → Storage → Blob

# ── Database ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Rate limiting (Redis) ───────────────────────────────────
# LOCAL:      redis://localhost:6379      (brew install redis)
# PRODUCTION: rediss://:password@host:6380 (Upstash free tier at console.upstash.com)
REDIS_URL=redis://localhost:6379

# ── Payments ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Integrations ────────────────────────────────────────────
PEXELS_API_KEY=                         # pexels.com/api
LTX_API_KEY=
HIGGSFIELD_CREDENTIALS=

# ── Admin / founder auth ─────────────────────────────────────
OWNER_CODE_YB=                          # secret code for your founder session
OWNER_CODE_AN=
BETA_CODES=                             # comma-separated list of beta invite codes

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=                         # from resend.com dashboard
FOUNDER_EMAIL=ybhagat2011@gmail.com      # only this email can trigger admin newsletter blasts
CRON_SECRET=                            # random secret — add same value to Vercel env vars for cron auth
NEXT_PUBLIC_APP_URL=https://brandlift.dev
